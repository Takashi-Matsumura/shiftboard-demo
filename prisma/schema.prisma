// shiftboard-demo: User / Session / Whiteboard の最小スキーマ
// Whiteboard.elements / appState は SQLite に Json 型がないため
// String で持ち、API 層で JSON.stringify / parse する。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("member") // "admin" | "member"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ステーション全員で 1 枚を共有する単一行モデル。id は固定の "default"。
model Whiteboard {
  id        String   @id @default("default")
  elements  String
  appState  String
  updatedAt DateTime @updatedAt
}

// スケジュール枠テンプレ。シングルトン (id="default") で 1 種類のみ。
// editingBy が非 null なら誰かが編集モード中で、その間 Whiteboard への書き込みはロックされる。
model Template {
  id               String    @id @default("default")
  elements         String    // grid 要素 (locked: true) を JSON.stringify した配列
  editingBy        String?   // 編集中ユーザの id。null なら開放されている
  editingStartedAt DateTime? // 自動解放のための参考用 (現状は手動解放のみ)
  updatedAt        DateTime  @updatedAt
}

// 「誰が」で選択する社員マスター。
// color はカードのフチ色 / バッジ色などに使う色 ID (lib/grid.ts の CardColorId)。
model Employee {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries ScheduleEntry[]
  records ScheduleRecord[] @relation("EmployeeRecords")
}

// 「誰に」で選択する顧客マスター。
model Customer {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries ScheduleEntry[]
  records ScheduleRecord[] @relation("CustomerRecords")
}

// 「何を」の業務マスター。
model Task {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries ScheduleEntry[]
  records ScheduleRecord[] @relation("TaskRecords")
}

// 1 枚のカード (Excalidraw 要素) に紐付く業務メタ情報。
// cardId は createCardElement() が発番する "card:..." 形式の文字列。
// who / what / toWhom はマスターからの選択 (未選択なら null)。
model ScheduleEntry {
  id        String    @id @default(cuid())
  cardId    String    @unique
  whoId     String?
  whatId    String?
  toWhomId  String?
  startAt   DateTime?
  endAt     DateTime?
  notes     String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  who    Employee? @relation(fields: [whoId], references: [id], onDelete: SetNull)
  what   Task?     @relation(fields: [whatId], references: [id], onDelete: SetNull)
  toWhom Customer? @relation(fields: [toWhomId], references: [id], onDelete: SetNull)

  @@index([cardId])
  @@index([whoId])
  @@index([whatId])
  @@index([toWhomId])
}

// 「予定 / 実績」記録。日付が変わったタイミングで前日のカード状態を
// `planned*` フィールドにスナップして 1 日 1 行 × 1 カードで保存する。
// `actual*` はデータパネル UI から後追いで実績入力するための欄。
// 同じ日 × 同じ cardId の二重登録は @@unique で防ぐ (snapshot は upsert で冪等)。
model ScheduleRecord {
  id             String    @id @default(cuid())
  date           DateTime              // ローカル日付の 0:00 を UTC に正規化して保存
  cardId         String                // 元のカード ID (Whiteboard.elements の rectangle.id)
  whoId          String?
  whatId         String?
  toWhomId       String?

  // 予定: snapshot 時に確定。以降は frozen
  plannedStartAt DateTime?
  plannedEndAt   DateTime?
  plannedNotes   String   @default("")

  // 実績: データパネルで後から書き込み
  actualStartAt  DateTime?
  actualEndAt    DateTime?
  actualNotes    String   @default("")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  who    Employee? @relation("EmployeeRecords", fields: [whoId],    references: [id], onDelete: SetNull)
  what   Task?     @relation("TaskRecords",     fields: [whatId],   references: [id], onDelete: SetNull)
  toWhom Customer? @relation("CustomerRecords", fields: [toWhomId], references: [id], onDelete: SetNull)

  @@unique([date, cardId])
  @@index([date])
  @@index([whoId])
  @@index([toWhomId])
}
